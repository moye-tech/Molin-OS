# ═══════════════════════════════════════════════════════════
# 墨麟OS — 环境变量模板
# 复制此文件为 ~/.hermes/.env 并填入真实密钥
# ═══════════════════════════════════════════════════════════

# ── AI 模型密钥 ──
DEEPSEEK_API_KEY=sk-your-deepseek-key
DASHSCOPE_API_KEY=sk-your-dashscope-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# ── 飞书 ──
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=your-verification-token

# ── 超级记忆 ──
SUPERMEMORY_API_KEY=sm_your-supermemory-key

# ── GitHub ──
GITHUB_TOKEN=ghp_your-github-token

# ── 墨麟OS ──
MOLIN_COMPANY_NAME=墨麟科技
MOLIN_MISSION=用AI重新定义商业运营
CHROMADB_PERSIST_DIR=~/.hermes/memory/chroma_db
FFMPEG_PATH=/usr/local/bin/ffmpeg
TTS_ENGINE=edge
LEARNING_ENABLED=true
LEARNING_CYCLE_HOURS=168

# ── 可选增强 ──
# BITABLE_BASE_TOKEN=
# BITABLE_TABLE_ID=
# FEISHU_DRIVE_ROOT_FOLDER=
# XIANYU_COOKIE=
# XHS_COOKIE=
