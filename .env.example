# 墨麟 Hermes OS — 环境变量配置
# ===============================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ── 核心配置 ──
MOLIN_COMPANY_NAME=墨麟 AI
MOLIN_MISSION=打造AI驱动的全自动一人公司

# ── Hermes Agent 配置 ──
HERMES_API_BASE=http://localhost:11434
HERMES_MODEL=deepseek-v4-pro
HERMES_PROVIDER=deepseek

# ── 发布平台 API Keys ──
# 小红书 (需cookie或API)
XHS_COOKIE=
XHS_API_KEY=

# 知乎
ZHIHU_COOKIE=

# 微博
WEIBO_ACCESS_TOKEN=

# 微信公众号
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 掘金
JUEJIN_COOKIE=

# X/Twitter
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── 视频引擎 ──
FFMPEG_PATH=ffmpeg
TTS_ENGINE=espeak  # 可选: espeak, edge, openai

# ── 闲鱼配置 ──
XIANYU_COOKIE=
XIANYU_ACCOUNT=

# ── 自学习 ──
LEARNING_ENABLED=true
LEARNING_CYCLE_HOURS=168  # 每周一次

# ── 告警 ──
ALERT_WEBHOOK=
ALERT_EMAIL=
