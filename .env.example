# 墨麟OS — 环境变量配置
# ===============================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
#
# 墨麟OS v1.0 — 完整环境变量清单

# ── 核心配置 ──
MOLIN_COMPANY_NAME=墨麟 AI
MOLIN_MISSION=打造AI驱动的全自动一人公司

# ── Hermes Agent 配置 ──
HERMES_API_BASE=http://localhost:11434
HERMES_MODEL=deepseek-v4-pro
HERMES_PROVIDER=deepseek

# ── 模型路由 Provider API Keys ──
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# OpenRouter (备用/高级模型路由)
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# OpenAI (可选)
OPENAI_API_KEY=

# ── 向量数据库 ──
# Qdrant（生产推荐）
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_MEMORY_MODE=false

# ChromaDB（本地/开发备用）
CHROMADB_PERSIST_DIR=~/.molin/vectors/

# ── 数据库 ──
# PostgreSQL (可选，用于结构化数据)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=molin_os
POSTGRES_USER=
POSTGRES_PASSWORD=

# Redis (已弃用 — 系统已改用文件EventBus和内存Pub/Sub，不再依赖Redis)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=***

# ── 发布平台 API Keys ──
# 小红书 (需cookie或API)
XHS_COOKIE=
XHS_API_KEY=***

# 知乎
ZHIHU_COOKIE=

# 微博
WEIBO_ACCESS_TOKEN=***

# 微信公众号
WECHAT_APP_ID=
WECHAT_APP_SECRET=***

# 掘金
JUEJIN_COOKIE=

# X/Twitter
X_API_KEY=***
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── 视频引擎 ──
FFMPEG_PATH=ffmpeg
TTS_ENGINE=espeak  # 可选: espeak, edge, openai

# ── 闲鱼配置 ──
XIANYU_COOKIE=
XIANYU_ACCOUNT=

# ── 自学习 ──
LEARNING_ENABLED=true
LEARNING_CYCLE_HOURS=168  # 每周一次

# ── 告警 ──
ALERT_WEBHOOK=
ALERT_EMAIL=

# ── 飞书集成 (可选) ──
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=

# ── 日志配置 ──
LOG_LEVEL=INFO
LOG_FILE_PATH=~/.molin/logs/moyer.log
AUDIT_LOG_ENABLED=true

# ── 安全 ──
TOKEN_ROTATION_DAYS=30
SECRETS_MANAGEMENT=env_file
