# ═════════════════════════════════════════
# 墨麟OS — .gitignore
# ═════════════════════════════════════════

# Secrets & Credentials — NEVER COMMIT
.env
**/.env
*.key
*.pem
*secret*
*password*
*token*
credentials*
**/auth.*
**/.env.*
!**/.env.example
!**/.env.dev.example

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg-info
dist/
build/
*.egg
.eggs/
*.egg-info

# Runtime output — not committed
output/
relay/*.md

# Virtual Environment
venv/
.venv/
env/
.env/
*.venv
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.iml

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Archives (retired/archived skills)
_archived/

# Logs & Cache
*.log
.coverage
.molin/
logs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Hermes Agent system files
.molin/

# Large reference docs (>500KB)
skills/mlops/training/unsloth/references/llms-full.md
skills/mlops/training/unsloth/references/llms-txt.md

# Old duplicate code directories (moved to molib/)
molin/agents_old/
molin/core_old/

# Local config overrides
config/local.*

# ═════════════════════════════════════════
# Assets that should be gitignored
# ═════════════════════════════════════════

# 闲鱼逆向JS (4.2MB — large binary, download not commit)
molib/xianyu/static/goofish_js_origin_version_2.js
molin/xianyu/static/goofish_js_origin_version_2.js

# Large JS assets (313KB)
molib/xianyu/utils/et_f.js

# Relay data (generated on-demand)
molin/relay/*.json

# Temporary docs / auto-generated reports
docs/absorption-report-*.md
docs/system-status-*.md

# Fork repos (downloaded on-demand)
fork_repos/

# Claude Code auto-generated
.claude/
CLAUDE.md

# Compressed archives
*.tar.gz
*.zip
!backup_*.tar.gz

# Backup directories
*_backup_*/
.gitnexus
