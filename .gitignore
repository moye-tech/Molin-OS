# ═════════════════════════════════════════
# 墨麟 Hermes OS — .gitignore
# ═════════════════════════════════════════

# Secrets & Credentials — NEVER COMMIT
.env
*.key
*.pem
*secret*
*password*
*token*
credentials*
**/auth.*

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# Virtual Environment
venv/
.venv/
env/
.env/
*.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Archives (retired/archived skills)
_archived/

# Logs & Cache
*.log
.coverage
.molin/
logs/
.pytest_cache/
.mypy_cache/
*.tar.gz
*.zip
!backup_*.tar.gz

# Backup archives
*_backup_*/

# Jupyter
.ipynb_checkpoints/

# Local config overrides
config/local.*

# ═════════════════════════════════════════
# Large binary files — > 50MB limit on GitHub
# ═════════════════════════════════════════

# 闲鱼逆向JS (4.2MB — large asset, download not commit)
molib/xianyu/static/goofish_js_origin_version_2.js
molin/xianyu/static/goofish_js_origin_version_2.js

# Large reference docs (>500KB)
skills/mlops/training/unsloth/references/llms-full.md
skills/mlops/training/unsloth/references/llms-txt.md

# Old duplicate code directories (moved to molib/)
molin/agents_old/
molin/core_old/

# Large JS assets (313KB)
molib/xianyu/utils/et_f.js