# ══════════════════════════════════════════
# 墨麟OS (Molin-OS) — .gitignore
# 标准化版本 v2.0 (2026-05-16)
# ══════════════════════════════════════════

# ─── Secrets & Credentials — NEVER COMMIT ───
.env
**/.env
*.key
*.pem
*secret*
*password*
**/token.*
!**/token_manager.*
!**/token_manager/**
credentials*
**/auth.json
**/auth.env
!**/.env.example
!**/.env.dev.example
*.token

# ─── Python Artifacts ───
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg-info
dist/
build/
*.egg
.eggs/
*.egg-info
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─── Virtual Environments ───
venv/
.venv/
env/
.env/
*.venv
.venv

# ─── IDE / Editor ───
.vscode/
.idea/
*.swp
*.swo
*~
*.iml
.claude/
CLAUDE.md

# ─── OS ───
.DS_Store
Thumbs.db
Desktop.ini

# Generated Runtime Data
relay/
**/relay/*.json
data/relay/
output/
data/relay/
logs/
*.log
.firecrawl/

# ─── Archives ───
_archived/
*.tar.gz
*.zip
!backup_*.tar.gz
*_backup_*/
restore_*.log

# ─── Hermes System Files ───
.molin/
.cron.db

# ─── Node.js (not a JS project) ───
node_modules/
package-lock.json
package.json

# ─── Large Runtime Binaries ───
molib/xianyu/static/goofish_js_origin_version_2.js
molin/xianyu/static/goofish_js_origin_version_2.js
molib/xianyu/utils/et_f.js

# ─── Temporary / Auto-generated ───
skills/mlops/training/unsloth/references/llms-full.md
skills/mlops/training/unsloth/references/llms-txt.md
docs/absorption-report-*.md
docs/system-status-*.md
fork_repos/

# ─── Old Code (moved to molib/) ───
molin/agents_old/
molin/core_old/

# ─── Submodule Externals (managed via .gitmodules) ───
